{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "SLACK_BOT_TOKEN",
        "SLACK_APP_TOKEN",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GITHUB_WEBHOOK_SECRET",
        "GITHUB_REDIRECT_URL",
        "GITHUB_APP_ID",
        "GITHUB_PRIVATE_KEY",
        "DATABASE_URL",
        "REDIS_URL",
        "LLM_API_KEY",
        "LLM_BASE_URL",
        "LLM_MODEL",
        "PORT",
        "COGNEE_API_KEY",
        "COGNEE_API_URL",
        "GRAPH_REBUILD_WORKSPACE_ID"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NODE_ENV",
        "SLACK_BOT_TOKEN",
        "SLACK_APP_TOKEN",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GITHUB_WEBHOOK_SECRET",
        "GITHUB_REDIRECT_URL",
        "GITHUB_APP_ID",
        "GITHUB_PRIVATE_KEY",
        "DATABASE_URL",
        "REDIS_URL",
        "LLM_API_KEY",
        "LLM_BASE_URL",
        "LLM_MODEL",
        "PORT"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "env": [
        "NODE_ENV",
        "SLACK_BOT_TOKEN",
        "SLACK_APP_TOKEN",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GITHUB_WEBHOOK_SECRET",
        "GITHUB_REDIRECT_URL",
        "GITHUB_APP_ID",
        "GITHUB_PRIVATE_KEY",
        "DATABASE_URL",
        "REDIS_URL",
        "LLM_API_KEY",
        "LLM_BASE_URL",
        "LLM_MODEL",
        "PORT"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
