# ── App ──
NODE_ENV=development
PORT=3000

# ── Slack ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# ── GitHub ──
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback

# ── Database ──
DATABASE_URL=postgresql://neuron:neuron_dev@localhost:5432/neuron

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── LLM (OpenAI-compatible: OpenAI, OpenRouter, Gemini, Groq, etc.) ──
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Other providers:
# OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1, LLM_MODEL=anthropic/claude-3.5-sonnet
# Gemini:      LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/, LLM_MODEL=gemini-2.0-flash
# Groq:        LLM_BASE_URL=https://api.groq.com/openai/v1, LLM_MODEL=llama-3.1-70b-versatile

# ── Cognee Cloud (optional — degrades to Postgres-only graph if unset) ──
# Ingest uses multipart FormData with datasetName (not JSON dataset_name).
COGNEE_API_URL=https://your-tenant.cognee.ai
COGNEE_API_KEY=ck_your_api_key

# ── Slack RTS notes ──
# Enable AI features / Real-time Search on the Slack app.
# REQUIRED for channel questions: search:read.public (add scope, then reinstall the app).
# Also useful: channels:history, groups:history
# Prefer user token for permission-aware assistant.search.context when available.
